# ─────────────────────────────────────────────────────────────
# whatsapp-claude-bridge configuration
# Copy this file to `.env` and fill it in.  NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# Which directory Claude Code runs in (the project it operates on).
# Use an absolute path. Defaults to this repo's own directory if unset.
WORKDIR=/Users/you/Documents/your-project

# Comma-separated list of WhatsApp JIDs allowed to send commands.
# Leave EMPTY to use note-to-self only (recommended & most secure):
# the bridge will only act on messages you send to YOURSELF.
# A JID looks like: 31612345678@s.whatsapp.net  (country code, no +, no spaces)
ALLOWED_JIDS=

# Optional command prefix. If set (e.g. "claude"), only messages that start
# with it are treated as tasks (so you can still use note-to-self normally).
# The prefix is stripped before the task is sent to Claude. Empty = every
# message in an allowed chat is a task.
COMMAND_PREFIX=

# Which agent CLI drives the work. One of: claude | codex | gemini | grok.
# Each must be installed and authenticated on this machine. You can also switch
# per-chat from WhatsApp with `/use <provider>`. Default: claude.
#   claude — full session continuity + cost reporting
#   codex  — OpenAI Codex CLI (resumable; run `codex login` first)
#   gemini — Google Gemini CLI (stateless per message)
#   grok   — xAI Grok CLI (stateless; flags best-effort)
PROVIDER=claude

# Optional model override passed to the selected provider's CLI.
# Empty = that CLI's own default. Examples: claude-opus-4-8 | gpt-5-codex | gemini-2.5-pro
MODEL=

# Max seconds a single task may run before it is killed. Default 600.
TASK_TIMEOUT_SECONDS=600

# While linking, write the pairing QR to qr.png and open it in the OS image
# viewer (easier to scan than terminal blocks). Set to false on a headless
# server. Default true.
QR_AUTO_OPEN=true

# On connect, find-or-create a dedicated WhatsApp group to use as the command
# channel (cleaner than note-to-self). Default true. Note-to-self still works
# either way.
CREATE_GROUP=true
GROUP_NAME=Claude Chat
