# ─────────────────────────────────────────────────────────────
# whatsapp-claude-bridge configuration
# Copy this file to `.env` and fill it in.  NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# Which directory Claude Code runs in (the project it operates on).
# Use an absolute path. Defaults to this repo's own directory if unset.
WORKDIR=/Users/you/Documents/your-project

# HARD LOCK: unprompted tasks (every message = a task, no trigger word needed)
# only ever run inside the dedicated group(s) below (see GROUP_NAME), and only
# on messages you send (or an allowlisted participant). It NEVER runs an
# unprompted task in note-to-self, your own number, DMs, or any other chat —
# no allowlist override there, so it can't collide with other tools on your
# WhatsApp.
#
# On top of that hard lock, the MENTION_TRIGGER below is a deliberate, narrow
# opt-in: typing it (e.g. "@computer") in ANY chat — but only when YOU send
# it, never other participants — makes the bridge read that chat's recent
# messages and reply there with full Claude Code power. See MENTION_TRIGGER.

# Optional command prefix. If set (e.g. "claude"), only messages in the group
# that start with it are treated as tasks. The prefix is stripped before the
# task runs. Empty = every message in the group is a task.
COMMAND_PREFIX=

# Which agent CLI drives the work. One of: claude | codex | gemini | grok.
# Each must be installed and authenticated on this machine. You can also switch
# per-chat from WhatsApp with `/use <provider>`. Default: claude.
#   claude — full session continuity + cost reporting
#   codex  — OpenAI Codex CLI (resumable; run `codex login` first)
#   gemini — Google Gemini CLI (stateless per message)
#   grok   — xAI Grok CLI (stateless; flags best-effort)
PROVIDER=claude

# Legacy model override for the default PROVIDER only. Prefer the per-provider
# settings below so switching agents never hands one CLI another CLI's model.
MODEL=
CLAUDE_MODEL=
CODEX_MODEL=
GEMINI_MODEL=
GROK_MODEL=

# Max seconds a single task may run before it is killed. Default 600.
TASK_TIMEOUT_SECONDS=600

# While linking, write the pairing QR to qr.png and open it in the OS image
# viewer (easier to scan than terminal blocks). Set to false on a headless
# server. Default true.
QR_AUTO_OPEN=true

# The dedicated WhatsApp group that is the bridge's ONLY command channel. On
# connect it finds-or-creates a group with this name; nothing outside it is
# ever processed. Keep CREATE_GROUP=true.
CREATE_GROUP=true
GROUP_NAME=Claude Chat

# Anywhere-in-WhatsApp trigger. When YOU (never other participants) write this
# word in ANY chat — a DM, a group you're not monitoring, anywhere — the
# bridge reads that chat's recent messages and replies right there, with the
# same full Claude Code power as the dedicated group (runs in WORKDIR, its
# own per-chat session). Set ENABLE_MENTION_TRIGGER=false to turn this off
# entirely and fall back to the dedicated-group-only behaviour.
ENABLE_MENTION_TRIGGER=true
MENTION_TRIGGER=@computer

# Optional per-trigger agent routing. Each trigger works in any chat (including
# a monitored command group) only when YOU type it. In ordinary chats the
# trigger must be the first token; command groups also allow it mid-message.
# Format: trigger:provider:model (model is optional for backward compatibility).
# Sessions stay independent per call sign within each chat, even when two call
# signs use the same provider.
# Example: @computer:claude:sonnet,@codex:codex:gpt-5.6
# Blank = MENTION_TRIGGER routes to PROVIDER.
MENTION_TRIGGERS=

# Extra visible prefixes used by other local WhatsApp automations. Messages
# sent from your account that begin with one of these are stored but NEVER run
# as tasks. Nora:, Computer:, Codex: and Bridge: are always protected.
BOT_REPLY_PREFIXES=

# ChatGPT-like follow-ups. In your self-chat, a leading call sign activates a
# sliding conversation window so later messages do not need the call sign.
# In any other ordinary chat, opt in explicitly with `@codex /chat` (or
# `@computer /chat`). Use /new for a fresh thread and /stop to leave the mode.
# 0 disables sticky conversations; blank uses the default (120). Waiting
# turns run FIFO, capped per chat.
CONVERSATION_MODE_MINUTES=120
CONVERSATION_QUEUE_LIMIT=10

# Instant acknowledgement. When on, a task dispatch fires a throwaway
# "🤖 On it…" line so you know it landed. Set to 0/false to silence it.
ACK_ENABLED=true

# Live progress rail. While a task runs, coalesced "⏳ …" lines report what the
# agent is doing. PROGRESS_INTERVAL_SECONDS is the delay before the FIRST line
# (a quick turn finishes before it and stays silent); clamps to 5–600s. Set to
# 0 to disable progress streaming entirely (keeps claude in json mode).
# PROGRESS_MAX_UPDATES caps how many progress lines one task may emit.
PROGRESS_INTERVAL_SECONDS=15
PROGRESS_MAX_UPDATES=8

# Background jobs. Long work (builds, full test suites, big refactors) runs as a
# background job that replies when done, freeing the chat immediately. Drive it
# with /job <task>, /jobs and /kill <id> from WhatsApp, or let the agent
# delegate. JOB_TIMEOUT_SECONDS floors at 60; the other two clamp as noted.
JOB_TIMEOUT_SECONDS=3600
MAX_CONCURRENT_JOBS=3
MAX_QUEUED_JOBS=10
