{
  "name": "whatsapp-claude-bridge",
  "version": "1.0.0",
  "description": "Message your computer on WhatsApp and have Claude Code do the work. A self-hosted bridge: WhatsApp -> Claude Code (headless) -> WhatsApp.",
  "type": "module",
  "license": "MIT",
  "author": "AI Makers Co",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "serve": "node dist/index.js",
    "install-service": "bash scripts/install-service.sh",
    "uninstall-service": "bash scripts/uninstall-service.sh"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.18",
    "dotenv": "^16.4.7",
    "pino": "^9.6.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.5",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
